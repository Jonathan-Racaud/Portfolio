---
import Button from "./Button.astro";

interface Link {
  label: string;
  href: string;
  variant?: "primary" | "secondary";
}

interface Props {
  title: string;
  description: string;
  links: Link[];
  tags?: string[];
}

const { title, description, links, tags = [] } = Astro.props;
---

<article class="project-card">
    <section>
        <h3 class="project-title">{title}</h3>
        <p class="project-description">{description}</p>
    </section>
    <div class="project-metadata">
        {
          tags.length > 0 && (
            <ul class="pill-list project-tags">
              {tags.map((tag) => (
                <li class="pill">{tag}</li>
              ))}
            </ul>
          )
        }
        <div class="project-links">
            {
              links.map((link) => (
                  <Button href={link.href} variant={link.variant ?? "secondary"} external>
                      {link.label}
                  </Button>
              ))
            }
        </div>
    </div>
</article>

<style>
  .project-card {
    padding: 24px;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: space-between;
  }

  .project-title {
    font-family: var(--font-sans);
    font-size: 1.08rem;
    margin-bottom: 10px;
  }

  .project-description {
    font-size: 1rem;
    margin: 0;
    color: var(--ink);
  }

  .project-tags {
    margin-top: 0;
  }

  .project-metadata {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .project-links {
      display: flex;
      gap: 5px;
      justify-content: space-between;
  }
</style>
