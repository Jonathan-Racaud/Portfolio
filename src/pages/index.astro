---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import CaseStudyPreview from "../components/CaseStudyPreview.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillsGrid from "../components/SkillsGrid.astro";
import Timeline from "../components/Timeline.astro";

const caseStudies = (await getCollection("caseStudies")).sort(
  (a, b) => a.data.order - b.data.order,
);

const personalProjects = [
  {
    title: "Mirror",
    description:
      "A desktop application that runs an LLM-driven interview on my career materials and produces a structured persona profile. I built a provider abstraction that lets users choose between hosted AI providers and local models — nothing leaves the device unless chosen.",
    tags: [],
    links: [
      {
        label: "View repo",
        href: "https://github.com/nc-750/Applications/tree/main/Mirror/App",
      },
      {
        label: "Try it",
        href: "https://mirror.nc-750.com",
        variant: "primary" as const,
      },
    ],
  },
  {
    title: "Astro Mind",
    tags: [],
    description:
      "An exploration of Retrieval-Augmented Generation architecture: combining semantic search with LLM responses to answer natural-language questions from a curated knowledge base. Built with Python, OpenAI SDK, and Qdrant.",
    links: [
      {
        label: "View repo",
        href: "https://github.com/Jonathan-Racaud/Astro-Mind",
        variant: "primary" as const,
      },
    ],
  },
];

const skillGroups = [
  {
    heading: "Languages",
    items: ["Swift", "C++", "C", "C#", "Python", "TypeScript"],
  },
  {
    heading: "Platforms & Domains",
    items: [
      "SDK Design",
      "Cross-platform Architecture",
      "iOS / SwiftUI",
      "Embedded (Arduino)",
      ".NET / ASP.NET Core",
      "Linux / NixOS",
    ],
  },
  {
    heading: "AI Application Engineering",
    items: [
      "LLM Integration",
      "RAG Pipelines",
      "Provider Abstraction",
      "Local-first AI Workflows",
    ],
  },
];

const experienceEntries = [
  {
    organization: "Amaris Consulting",
    role: "Experienced Consultant",
    timeframe: "2020 – 2025",
    summary: "Developed core components of a cross-platform automotive SDK and contributed to C#/.NET backend services for on-street parking data.",
  },
  {
    organization: "NConcepts",
    role: "Software Engineer",
    timeframe: "2017 – 2019",
    summary: "Built interactive systems combining embedded hardware, desktop applications, and cross-platform mobile interfaces.",
  },
  {
    organization: "Office Micro",
    role: "Full Stack Developer",
    timeframe: "2016 – 2017",
    summary: "Designed and developed a RESTful web service and frontend mapping application for city halls.",
  },
  {
    organization: "Class-Web",
    role: "PHP Backend Developer",
    timeframe: "2015",
    summary: "Maintained an e-commerce web application and prototyped payment integrations.",
  },
  {
    organization: "Office Micro",
    role: "Software Developer",
    timeframe: "2014 – 2015",
    summary: "Developed a Windows desktop application to manage and automate scripting workflows.",
  },
  {
    organization: "Sopra Group",
    role: "Software Engineer",
    timeframe: "2013",
    summary: "Researched and presented on integrating Java Ecore into embedded software workflows.",
  },
];
---

<BaseLayout
  title="Jonathan Racaud - SDK / Platform Software Engineer"
  description="SDK / Platform Software Engineer | Bridging Embedded Systems, Mobile Platforms & Backend Services | Exploring AI-powered Application"
>
  <Hero
    name="Jonathan Racaud"
    tagline="SDK / Platform Software Engineer | Bridging Embedded Systems, Mobile Platforms & Backend Services | Exploring AI-powered Application"
  />

  <About />

  <section id="case-studies">
    <p class="section-label">Case studies</p>
    <div class="case-study-list">
      {
        caseStudies.map((entry) => (
          <CaseStudyPreview
            href={`/case-studies/${entry.id}`}
            organization={entry.data.organization}
            role={entry.data.role}
            timeframe={entry.data.timeframe}
            title={entry.data.title}
            hook={entry.data.hook}
          />
        ))
      }
    </div>
  </section>

  <section id="projects">
    <p class="section-label">Selected Personal projects</p>
    <div class="project-grid">
      {
        personalProjects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            links={project.links}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .case-study-list {
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }

  .project-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
