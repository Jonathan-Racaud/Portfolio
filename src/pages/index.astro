---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import CaseStudyPreview from "../components/CaseStudyPreview.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillsGrid from "../components/SkillsGrid.astro";

const caseStudies = (await getCollection("caseStudies")).sort(
  (a, b) => a.data.order - b.data.order,
);

const personalProjects = [
  {
    title: "Mirror",
    description:
      "Mirror interviews you with AI, finds patterns you missed, and produces a private insight document and a polished public profile. Nothing leaves your device except the requests you send to your own AI provider.",
    tags: ["Typescript", "Vue.js", "LLMs", "OpenAI SDK"],
    links: [
      {
        label: "View repo",
        href: "https://github.com/nc-750/Applications/tree/main/Mirror/App",
      },
      {
        label: "Try it",
        href: "https://mirror.nc-750.com",
        variant: "primary" as const,
      },
    ],
  },
  {
    title: "Astro Mind",
    description:
      "A friendly AI assistant for Elite Dangerous commanders, designed to help you explore and understand the capabilities of ships across the galaxy.",
    tags: ["Python", "LLM", "RAG"],
    links: [
      {
        label: "View repo",
        href: "https://github.com/Jonathan-Racaud/Astro-Mind",
        variant: "primary" as const,
      },
    ],
  },
  {
    title: "Monthly Expenses",
    description:
      "A simple application that helps you track your monthly expenses and incomes.",
    tags: ["Flutter", "Dart"],
    links: [
      {
        label: "View repo",
        href: "https://github.com/Jonathan-Racaud/Monthly-Expenses",
        variant: "primary" as const,
      },
    ],
  },
  {
    title: "ijo",
    description:
      "A small programing language to explore what a keyword-free programming language could look like.",
    tags: ["nim"],
    links: [
      {
        label: "View repo",
        href: "https://github.com/Jonathan-Racaud/ijo",
        variant: "primary" as const,
      },
    ],
  },
];

const skillGroups = [
  {
    heading: "Programming Languages",
    items: ["Swift", "C++", "C", "C#", "Python", "TypeScript"],
  },
  {
    heading: "Platforms",
    items: [
      "iOS / SwiftUI",
      "Embedded (Arduino, ESP32)",
      ".NET / ASP.NET Core",
      "Linux / NixOS",
    ],
  },
  {
    heading: "Domains",
    items: [
      "SDK design",
      "Software design",
      "Applied LLMs",
      "Cross-platform development",
      "Self-hosted infrastructure",
    ],
  },
];
---

<BaseLayout
  title="Jonathan Racaud - Software Engineer"
  description="Software engineer - iOS, Web, Applied LLMs."
>
  <Hero
    name="Jonathan Racaud"
    tagline="Software engineer - iOS, Web, Applied LLMs"
  />

  <About />

  <section id="case-studies">
    <p class="section-label">Case studies</p>
    <div class="case-study-list">
      {
        caseStudies.map((entry) => (
          <CaseStudyPreview
            href={`/case-studies/${entry.id}`}
            organization={entry.data.organization}
            role={entry.data.role}
            timeframe={entry.data.timeframe}
            title={entry.data.title}
            hook={entry.data.hook}
          />
        ))
      }
    </div>
  </section>

  <section id="projects">
    <p class="section-label">Personal projects</p>
    <div class="project-grid">
      {
        personalProjects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            links={project.links}
          />
        ))
      }
    </div>
  </section>

  <section id="skills">
    <p class="section-label">What I work with</p>
    <SkillsGrid groups={skillGroups} />
  </section>
</BaseLayout>

<style>
  .case-study-list {
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }

  .project-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
