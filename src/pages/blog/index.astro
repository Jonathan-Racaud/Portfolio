---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
  title="Notes — Jonathan Racaud"
  description="Occasional writing on integration work, embedded, and applied LLMs."
>
  <div class="prose">
    <header class="case-study-header">
      <h1>Notes</h1>
      <p class="meta">Occasional writing.</p>
    </header>

    {
      posts.length === 0 ? (
        <p>
          Nothing published yet. I write here about integration work, embedded,
          and applied LLMs — the kinds of problems where two systems have to
          learn to talk to each other. Check back.
        </p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`}>
                <span class="post-date">
                  <time datetime={post.data.publishedAt.toISOString()}>
                    {post.data.publishedAt.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                </span>
                <span class="post-title">{post.data.title}</span>
              </a>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list li {
    padding: 20px 0;
    border-top: 1px solid var(--rule);
  }

  .post-list li:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .post-list a {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .post-date {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--ink-soft);
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    color: var(--ink);
    font-weight: 500;
  }

  .post-list a:hover .post-title {
    color: var(--accent);
  }

  .post-desc {
    margin: 6px 0 0;
    color: var(--ink-soft);
    font-size: 0.98rem;
  }
</style>
