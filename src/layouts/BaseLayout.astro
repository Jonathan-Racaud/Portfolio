---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  pathname?: string;
}

const {
  title,
  description = "Jonathan Racaud - SDK / Platform Software Engineer | Bridging Embedded Systems, Mobile Platforms & Backend Services | Exploring AI-powered Application.",
  pathname,
} = Astro.props;

const currentPath = pathname ?? Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return currentPath === "/" || currentPath === "";
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site">
      <nav class="site-nav" aria-label="Primary">
        <a href="/" class="brand">Home</a>
        <span class="spacer"></span>
        <a href="/#case-studies" aria-current={isActive("/case-studies") ? "page" : undefined}>Case studies</a>
        <a href="/#projects">Projects</a>
      </nav>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div>&copy; {new Date().getFullYear()} Jonathan Racaud</div>
        <div class="footer-links">
          <a href="mailto:contact@jracaud.com">contact@jracaud.com</a>
          <a href="https://www.linkedin.com/in/jonathan-racaud" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://github.com/Jonathan-Racaud/" target="_blank" rel="noopener">GitHub</a>
        </div>
      </footer>
    </div>
  </body>
</html>
